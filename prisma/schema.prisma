generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model bookings {
  id          Int             @id @default(autoincrement())
  guest_id    Int
  room_id     Int
  check_in    DateTime
  check_out   DateTime
  total_price Decimal         @db.Decimal(12, 2)
  status      bookings_status @default(pending)
  created_at  DateTime        @default(now())
  updated_at  DateTime
  guests      guests          @relation(fields: [guest_id], references: [id], onDelete: Cascade)
  rooms       rooms           @relation(fields: [room_id], references: [id], onDelete: Cascade)
  payments    payments[]

  @@index([guest_id], map: "bookings_guest_id_fkey")
  @@index([room_id], map: "bookings_room_id_fkey")
}

model guests {
  id                Int                 @id @default(autoincrement())
  name              String
  email             String              @unique
  email_verified_at DateTime?
  password          String
  phone             String
  identity_number   String
  photo_url         String?
  created_at        DateTime            @default(now())
  updated_at        DateTime
  bookings          bookings[]
  restaurant_orders restaurant_orders[]
}

model payments {
  id                  Int                     @id @default(autoincrement())
  booking_id          Int?
  restaurant_order_id Int?                    @unique
  amount              Decimal                 @db.Decimal(12, 2)
  payment_method      String?
  payment_status      payments_payment_status @default(pending)
  note                String?                 @db.Text
  created_at          DateTime                @default(now())
  updated_at          DateTime
  bookings            bookings?               @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  restaurant_orders   restaurant_orders?      @relation(fields: [restaurant_order_id], references: [id], onDelete: Cascade)

  @@index([booking_id], map: "payments_booking_id_fkey")
}

model restaurant_menus {
  id                       Int                        @id @default(autoincrement())
  name                     String                     @unique
  description              String                     @db.Text
  price                    Decimal                    @db.Decimal(12, 2)
  foto_url                 String?
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  restaurant_order_details restaurant_order_details[]
}

model restaurant_order_details {
  id                  Int               @id @default(autoincrement())
  restaurant_order_id Int
  restaurant_menu_id  Int
  quantity            Int
  price               Decimal           @db.Decimal(12, 2)
  restaurant_menus    restaurant_menus  @relation(fields: [restaurant_menu_id], references: [id], onDelete: Cascade)
  restaurant_orders   restaurant_orders @relation(fields: [restaurant_order_id], references: [id], onDelete: Cascade)

  @@index([restaurant_menu_id], map: "restaurant_order_details_restaurant_menu_id_fkey")
  @@index([restaurant_order_id], map: "restaurant_order_details_restaurant_order_id_fkey")
}

model restaurant_orders {
  id                       Int                        @id @default(autoincrement())
  guest_id                 Int
  total_price              Decimal                    @db.Decimal(12, 2)
  status                   String                     @default("ordered")
  created_at               DateTime                   @default(now())
  updated_at               DateTime
  payments                 payments?
  restaurant_order_details restaurant_order_details[]
  guests                   guests                     @relation(fields: [guest_id], references: [id], onDelete: Cascade)

  @@index([guest_id], map: "restaurant_orders_guest_id_fkey")
}

model room_types {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  foto_url    String?
  created_at  DateTime @default(now())
  updated_at  DateTime
  rooms       rooms[]
}

model rooms {
  id           Int          @id @default(autoincrement())
  room_number  String       @unique
  status       rooms_status @default(available)
  room_type_id Int
  created_at   DateTime     @default(now())
  updated_at   DateTime
  bookings     bookings[]
  room_types   room_types   @relation(fields: [room_type_id], references: [id], onDelete: Cascade)

  @@index([room_type_id], map: "rooms_room_type_id_fkey")
}

model users {
  id                Int        @id @default(autoincrement())
  name              String
  email             String     @unique
  email_verified_at DateTime?
  password          String
  remember_token    String?    @db.VarChar(512)
  role              users_role @default(admin)
  created_at        DateTime   @default(now())
  updated_at        DateTime
}

enum rooms_status {
  available
  occupied
  maintenance
}

enum payments_payment_status {
  pending
  paid
  failed
}

enum bookings_status {
  pending
  confirmed
  checked_in
  checked_out
  cancelled
}

enum users_role {
  admin
  management
}
